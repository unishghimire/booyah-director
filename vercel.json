{
  "version": 2,
  "buildCommand": "cd netlify-app && npm install && npm run build",
  "outputDirectory": "netlify-app/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/controller.html", "destination": "/controller.html" },
    { "source": "/overlay.html", "destination": "/overlay.html" },
    { "source": "/((?!api/|controller.html|overlay.html).*)", "destination": "/index.html" }
  ]
}
