{
  "version": 2,
  "buildCommand": "cd netlify-app && npm install && npm run build",
  "outputDirectory": "netlify-app/dist",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
