{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        "booyah": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid",
          ".validate": "newData.hasChildren(['overlay_state'])"
        }
      }
    },

    "booyah_admin": {
      "admins": {
        ".read": "auth != null",
        ".write": false
      },
      "users": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": false
        }
      },
      "promo_codes": {
        ".read": "auth != null",
        ".write": false
      },
      "share_tokens": {
        ".read": true,
        ".write": false
      },
      "settings": {
        ".read": "auth != null",
        ".write": false
      }
    },

    "ping": {
      ".read": true,
      ".write": false
    }
  }
}
