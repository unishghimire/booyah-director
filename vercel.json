{
  "version": 2,
  "buildCommand": "cd netlify-app && npm install && npm run build && cp -r api/* ../api/",
  "outputDirectory": "netlify-app/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)",     "dest": "/index.html"   }
  ]
}
